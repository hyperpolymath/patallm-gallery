{
  "name": "@hyperpolymath/claude-gitlab-bridge",
  "version": "1.0.0",
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-env src/index.ts",
    "dev": "deno run --allow-net --allow-read --allow-env --watch src/index.ts",
    "test": "deno test --allow-all",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "imports": {
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.30.0",
    "express": "npm:express@^4.18.2",
    "gitlab": "npm:gitlab@^14.2.2",
    "zod": "npm:zod@^3.22.4",
    "dotenv": "npm:dotenv@^16.3.1"
  }
}
